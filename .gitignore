*.pyo
*.pyd
*.egg-info/
dist/
build/

# ── Variables de entorno / Secrets ───────
.env
.env.*
*.env

# ── Sistemas operativos ──────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDEs y editores ──────────────────────
.vscode/
.idea/
*.suo
*.user

# ── Logs ─────────────────────────────────
*.log
logs/
